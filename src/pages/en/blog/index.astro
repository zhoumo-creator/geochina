---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../../../components/BaseHead.astro';
import Footer from '../../../components/Footer.astro';
import FormattedDate from '../../../components/FormattedDate.astro';
import Header from '../../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../../consts';

const allPosts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
// Filter: only show English posts (-en suffix)
const posts = allPosts.filter(post => post.id.endsWith('-en'));
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Blog — ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
		<style>
			main {
				width: 960px;
			}
			.blog-header {
				margin-bottom: 2.5em;
			}
			.blog-header h1 {
				font-size: 2.4em;
				margin-bottom: 0.2em;
			}
			.blog-header p {
				color: rgb(var(--gray));
				font-size: 16px;
			}
			ul {
				display: flex;
				flex-direction: column;
				gap: 0;
				list-style-type: none;
				margin: 0;
				padding: 0;
			}
			ul li {
				border-bottom: 1px solid rgba(var(--gray-light), 0.5);
			}
			ul li:last-child {
				border-bottom: none;
			}
			ul li a {
				display: flex;
				justify-content: space-between;
				align-items: baseline;
				gap: 1.5em;
				padding: 1.4em 0;
				text-decoration: none;
				transition: all 0.2s;
			}
			ul li a:hover {
				padding-left: 0.5em;
			}
			ul li a:hover .title {
				color: rgb(var(--accent));
			}
			.title {
				margin: 0;
				color: rgb(var(--black));
				line-height: 1.3;
				font-size: 1.15em;
			}
			.date {
				margin: 0;
				color: rgb(var(--gray));
				font-size: 14px;
				white-space: nowrap;
				flex-shrink: 0;
			}
			.tags {
				display: flex;
				gap: 6px;
				margin-top: 4px;
			}
			.tag {
				font-size: 12px;
				color: rgb(var(--gray));
				background: rgba(var(--gray-light), 0.3);
				padding: 2px 8px;
				border-radius: 4px;
			}
			.post-info {
				flex: 1;
			}
			@media (max-width: 720px) {
				ul li a {
					flex-direction: column;
					gap: 0.3em;
				}
			}
		</style>
	</head>
	<body>
		<Header lang="en" />
		<main>
			<div class="blog-header">
				<h1>Blog</h1>
				<p>GEO insights, industry updates, and hands-on experiments</p>
			</div>
			<section>
				<ul>
					{
						posts.map((post) => (
							<li>
								<a href={`/blog/${post.id}/`}>
									<div class="post-info">
										<h4 class="title">{post.data.title}</h4>
										{post.data.tags && (
											<div class="tags">
												{post.data.tags.slice(0, 3).map((tag: string) => (
													<span class="tag">{tag}</span>
												))}
											</div>
										)}
									</div>
									<p class="date">
										<FormattedDate date={post.data.pubDate} />
									</p>
								</a>
							</li>
						))
					}
				</ul>
			</section>
		</main>
		<Footer lang="en" />
	</body>
</html>
