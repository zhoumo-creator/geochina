---
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import DitherIsland from '../../components/DitherIsland.jsx';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
	.filter(post => post.id.endsWith('-en'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title="GEO China — Get Cited by AI Search Engines" description="The #1 Chinese resource for Generative Engine Optimization (GEO). Learn how to get your brand cited by ChatGPT, Perplexity, and Google AI Overview." />
	</head>
	<body>
		<Header lang="en" />

		<section class="hero">
			<div class="hero-text">
				<h1>
					Get Cited by<br/>AI Search Engines.
				</h1>
				<a href="/en/services" class="btn-dark">
					Learn More
					<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M7 17L17 7M17 7H7M17 7V17"/></svg>
				</a>
			</div>
			<div class="hero-canvas">
				<DitherIsland client:load />
			</div>
		</section>

		<section class="stats-strip">
			<div class="stats-inner">
				<div class="stat-item">
					<span class="stat-value">33 <small>×</small></span>
					<span class="stat-desc">Rootly's AI citation growth after implementing GEO strategies</span>
				</div>
				<div class="stat-item">
					<span class="stat-value">78.72 <small>%</small></span>
					<span class="stat-desc">Probability of being cited in AI-generated summaries with GEO optimization</span>
				</div>
				<div class="stat-item">
					<span class="stat-value">100 <small>M</small></span>
					<span class="stat-desc">Weekly users getting information through AI search engines in China</span>
				</div>
			</div>
			<div class="scroll-hint">
				<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 5v14M5 12l7 7 7-7"/></svg>
				SCROLL DOWN
			</div>
		</section>

		<main>
			<section class="tech-section">
				<div class="section-label"><span class="label-dot"></span> Methodology</div>
				<div class="tech-list">
					<a href="/blog" class="tech-row">
						<span class="tech-num">01</span>
						<span class="tech-title">Citation Triggers</span>
						<span class="tech-arrow">↗</span>
					</a>
					<a href="/blog" class="tech-row">
						<span class="tech-num">02</span>
						<span class="tech-title">Entity-first Strategy</span>
						<span class="tech-arrow">↗</span>
					</a>
					<a href="/blog" class="tech-row">
						<span class="tech-num">03</span>
						<span class="tech-title">Structured Data for AI</span>
						<span class="tech-arrow">↗</span>
					</a>
					<a href="/blog" class="tech-row">
						<span class="tech-num">04</span>
						<span class="tech-title">AI Crawler Management</span>
						<span class="tech-arrow">↗</span>
					</a>
				</div>
			</section>

			<section class="what-section">
				<div class="what-grid">
					<div class="what-left">
						<div class="section-label"><span class="label-dot"></span> Concept</div>
						<h2>SEO optimizes ranking.<br/>GEO optimizes citation.</h2>
					</div>
					<div class="what-right">
						<p>
							Traditional SEO aims to get your website on the first page of Google search results.
							GEO aims to get AI systems — ChatGPT, Perplexity, Google AI Overview — to actively cite your content as an information source.
						</p>
						<p>
							According to Princeton research, structured GEO strategies can increase content visibility in AI-generated answers by up to <strong>40%</strong>.
							Traffic referred by AI typically converts at <strong>5×</strong> the rate of traditional search.
						</p>
					</div>
				</div>
			</section>

			<section class="cases-section">
				<div class="section-label"><span class="label-dot"></span> Real Cases</div>
				<h2>A proven growth engine</h2>
				<div class="cases-grid">
					<div class="case-card">
						<span class="case-value">10×</span>
						<p>Rootly — AI citation rate growth</p>
					</div>
					<div class="case-card">
						<span class="case-value">1,119%</span>
						<p>E-commerce brand — AI traffic YoY</p>
					</div>
					<div class="case-card">
						<span class="case-value">6×</span>
						<p>Grüns — AI visibility in 60 days</p>
					</div>
					<div class="case-card">
						<span class="case-value">+32%</span>
						<p>Smart Rent — SQL growth in 6 weeks</p>
					</div>
				</div>
			</section>

			<section class="blog-section">
				<h2>Latest Articles</h2>
				<div class="posts-list">
					{posts.map((post) => (
						<a href={`/blog/${post.id}/`} class="post-row">
							<div class="post-info">
								<time datetime={post.data.pubDate.toISOString()}>
									{post.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
								</time>
								<h3>{post.data.title}</h3>
							</div>
							<span class="post-arrow">→</span>
						</a>
					))}
				</div>
			</section>

			<section class="cta-section">
				<h2>Start Your GEO Journey</h2>
				<p>The #1 Chinese resource for Generative Engine Optimization.</p>
				<div class="cta-buttons">
					<a href="/en/services" class="btn-dark">
						View Services
						<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M7 17L17 7M17 7H7M17 7V17"/></svg>
					</a>
					<a href="mailto:hi@geochina.co" class="btn-outline">
						Contact Us
						<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
					</a>
				</div>
			</section>
		</main>
		<Footer lang="en" />
	</body>
</html>

<style>
	.hero {
		max-width: var(--max-w-wide);
		margin: 0 auto;
		padding: 4em 1.5em 0;
		display: grid;
		grid-template-columns: 1fr 1.4fr;
		gap: 3em;
		align-items: center;
	}
	.hero h1 { font-size: 3.2em; line-height: 1.15; letter-spacing: -0.03em; margin-bottom: 1em; }
	.btn-dark { display: inline-flex; align-items: center; gap: 8px; padding: 14px 28px; background: var(--black); color: white; border-radius: var(--radius); font-weight: 600; font-size: 15px; text-decoration: none; transition: all 0.2s; }
	.btn-dark:hover { background: #333; transform: translateY(-1px); box-shadow: 0 4px 16px rgba(0,0,0,0.15); color: white; }
	.hero-canvas { width: 100%; height: 340px; border-radius: var(--radius-lg); overflow: hidden; background: #f0f0ec; }
	.stats-strip { max-width: var(--max-w-wide); margin: 0 auto; padding: 4em 1.5em 3em; border-bottom: 1px solid var(--border); position: relative; }
	.stats-inner { display: grid; grid-template-columns: repeat(3, 1fr); gap: 3em; }
	.stat-value { display: block; font-family: var(--font-serif); font-size: 3.5em; font-weight: 400; color: var(--black); letter-spacing: -0.02em; line-height: 1; margin-bottom: 16px; }
	.stat-value small { font-size: 0.5em; color: var(--text-muted); font-weight: 400; }
	.stat-desc { display: block; font-size: 14px; color: var(--text-secondary); line-height: 1.6; }
	.scroll-hint { position: absolute; bottom: 2em; left: 1.5em; display: flex; align-items: center; gap: 8px; font-size: 11px; font-weight: 600; letter-spacing: 0.1em; color: var(--text-muted); }
	.tech-section { padding: 4em 0 2em; border-bottom: 1px solid var(--border); }
	.section-label { display: flex; align-items: center; gap: 8px; font-size: 12px; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: var(--text-muted); margin-bottom: 2em; }
	.label-dot { width: 6px; height: 6px; background: var(--black); display: inline-block; }
	.tech-list { display: flex; flex-direction: column; }
	.tech-row { display: flex; align-items: center; justify-content: space-between; padding: 1.4em 0; border-top: 1px solid var(--border-light); text-decoration: none; color: var(--text); transition: padding-left 0.2s; }
	.tech-row:hover { padding-left: 12px; }
	.tech-num { font-size: 14px; color: var(--text-muted); min-width: 40px; }
	.tech-title { flex: 1; font-size: 1.15em; font-weight: 700; }
	.tech-arrow { font-size: 1.2em; color: var(--text-muted); transition: transform 0.2s; }
	.tech-row:hover .tech-arrow { transform: translate(3px, -3px); color: var(--black); }
	.what-section { padding: 4em 0; border-bottom: 1px solid var(--border); }
	.what-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 4em; }
	.what-left h2 { font-size: 2.2em; margin-top: 0.5em; }
	.what-right p { font-size: 16px; color: var(--text-secondary); line-height: 1.85; }
	.what-right strong { color: var(--black); }
	.cases-section { padding: 4em 0; border-bottom: 1px solid var(--border); }
	.cases-section h2 { margin-bottom: 1.5em; }
	.cases-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 0; }
	.case-card { padding: 2em 1.5em; border-left: 1px solid var(--border); }
	.case-card:first-child { border-left: none; padding-left: 0; }
	.case-value { display: block; font-family: var(--font-serif); font-size: 2.8em; font-weight: 400; color: var(--black); letter-spacing: -0.02em; line-height: 1; margin-bottom: 14px; }
	.case-card p { font-size: 14px; color: var(--text-secondary); margin: 0; line-height: 1.5; }
	.blog-section { padding: 4em 0 2em; }
	.blog-section h2 { margin-bottom: 1em; }
	.post-row { display: flex; align-items: center; justify-content: space-between; padding: 1.5em 0; border-top: 1px solid var(--border-light); text-decoration: none; transition: padding-left 0.2s; }
	.post-row:last-child { border-bottom: 1px solid var(--border-light); }
	.post-row:hover { padding-left: 12px; }
	.post-info time { font-size: 13px; color: var(--text-muted); display: block; margin-bottom: 4px; }
	.post-info h3 { font-family: var(--font-sans); font-size: 1.05em; font-weight: 700; color: var(--black); transition: color 0.15s; }
	.post-row:hover h3 { color: var(--accent); }
	.post-arrow { font-size: 1.3em; color: var(--text-muted); transition: transform 0.15s; }
	.post-row:hover .post-arrow { transform: translateX(4px); color: var(--black); }
	.cta-section { text-align: center; padding: 5em 2em; margin: 2em 0; background: var(--bg-section); border-radius: var(--radius-lg); }
	.cta-section h2 { margin-bottom: 0.4em; font-size: 2em; }
	.cta-section p { margin-bottom: 1.5em; font-size: 16px; }
	.cta-buttons { display: flex; gap: 12px; justify-content: center; align-items: center; flex-wrap: wrap; }
	.btn-outline { display: inline-flex; align-items: center; gap: 8px; padding: 14px 28px; background: transparent; color: var(--black); border: 1.5px solid var(--black); border-radius: var(--radius); font-weight: 600; font-size: 15px; text-decoration: none; transition: all 0.2s; }
	.btn-outline:hover { background: var(--black); color: white; transform: translateY(-1px); box-shadow: 0 4px 16px rgba(0,0,0,0.15); }
	@media (max-width: 720px) {
		.hero { grid-template-columns: 1fr; padding-top: 2.5em; }
		.hero h1 { font-size: 2.4em; }
		.hero-canvas { height: 280px; }
		.stats-inner { grid-template-columns: 1fr; gap: 2em; }
		.stat-value { font-size: 2em; }
		.scroll-hint { display: none; }
		.what-grid { grid-template-columns: 1fr; gap: 1.5em; }
		.cases-grid { grid-template-columns: 1fr 1fr; }
		.case-card { border-left: none; border-top: 1px solid var(--border); padding-left: 0; }
		.case-card:first-child, .case-card:nth-child(2) { border-top: none; }
	}
</style>
