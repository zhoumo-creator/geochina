---
import HeaderLink from './HeaderLink.astro';

interface Props {
	lang?: string;
}

const { lang = 'zh' } = Astro.props;
const isEn = lang === 'en';
const prefix = isEn ? '/en' : '';
---

<header>
	<nav>
		<div class="nav-left">
			<HeaderLink href={`${prefix}/`}>Homepage</HeaderLink>
			<HeaderLink href={isEn ? '/blog' : '/blog'}>Blog</HeaderLink>
			<HeaderLink href={`${prefix}/services`}>Services</HeaderLink>
		</div>
		<a href={`${prefix}/`} class="site-logo">
			<svg width="28" height="28" viewBox="0 0 28 28" fill="none">
				<rect x="2" y="2" width="10" height="10" fill="#1a7a4c"/>
				<rect x="16" y="2" width="10" height="10" fill="#E8A838"/>
				<rect x="2" y="16" width="10" height="10" fill="#D94B3B"/>
				<rect x="16" y="16" width="10" height="10" fill="#2563EB"/>
			</svg>
		</a>
		<div class="nav-right">
			<HeaderLink href={`${prefix}/about`}>About</HeaderLink>
			<div class="lang-switch">
				<a href={isEn ? '/' : '/en/'} class="lang-btn" title={isEn ? '切换到中文' : 'Switch to English'}>
					{isEn ? '中文' : 'EN'}
				</a>
			</div>
			<a href="mailto:hello@geochina.co" class="nav-link-external">
				Contact
				<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M7 17L17 7M17 7H7M17 7V17"/></svg>
			</a>
		</div>
	</nav>
</header>
<style>
	header {
		position: sticky;
		top: 0;
		z-index: 100;
		background: rgba(255, 255, 255, 0.95);
		backdrop-filter: blur(16px);
		-webkit-backdrop-filter: blur(16px);
		border-bottom: 1px solid var(--border-light);
	}
	nav {
		max-width: var(--max-w-wide);
		margin: 0 auto;
		padding: 0 1.5em;
		display: grid;
		grid-template-columns: 1fr auto 1fr;
		align-items: center;
		height: 56px;
	}
	.nav-left {
		display: flex;
		gap: 0;
	}
	.nav-right {
		display: flex;
		gap: 0;
		justify-content: flex-end;
		align-items: center;
	}
	.nav-left a, .nav-right a {
		padding: 6px 16px;
		color: var(--text-secondary);
		text-decoration: none;
		font-size: 14px;
		font-weight: 500;
		transition: color 0.15s;
	}
	.nav-left a:hover, .nav-right a:hover {
		color: var(--black);
	}
	.nav-left a.active {
		color: var(--black);
		text-decoration: underline;
		text-underline-offset: 4px;
	}
	.site-logo {
		display: flex;
		align-items: center;
		justify-content: center;
		text-decoration: none;
	}
	.nav-link-external {
		display: inline-flex;
		align-items: center;
		gap: 4px;
	}
	.lang-switch {
		display: flex;
		align-items: center;
	}
	.lang-btn {
		padding: 4px 10px !important;
		font-size: 12px !important;
		font-weight: 600 !important;
		border: 1px solid var(--border);
		border-radius: 4px;
		color: var(--text-muted) !important;
		transition: all 0.15s;
	}
	.lang-btn:hover {
		border-color: var(--black) !important;
		color: var(--black) !important;
	}
	@media (max-width: 720px) {
		nav { grid-template-columns: 1fr auto; }
		.nav-right { display: none; }
		.nav-left a { padding: 6px 10px; font-size: 13px; }
	}
</style>
